[jira]
# Jira Server / Data Center base URL, no trailing slash, e.g. https://jira.acme.com
base_url = https://YOURSITE.example.com

# Your Jira account username (NOT email, unless your login is an email)
username = your_username

# Your actual account password.
# NOTE: password Basic auth works on Jira Server / Data Center. Atlassian Cloud
# rejects passwords and requires an API token instead.
password = PASTE_YOUR_PASSWORD_HERE

# JQL selecting the issues you want to chart later.
jql = ORDER BY created DESC
